{
  "name": "magicpin-vera-bot",
  "version": "1.0.0",
  "description": "Production-grade AI decision engine for the Magicpin Vera Bot Challenge",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --test tests/*.test.js",
    "test:context": "node --test tests/contextStore.test.js",
    "test:validators": "node --test tests/validators.test.js",
    "test:memory": "node --test tests/merchantMemory.test.js",
    "test:engine": "node --test tests/decisionEngine.test.js",
    "test:versioning": "node --test tests/contextVersioning.test.js",
    "test:replay": "node --test tests/replayProtection.test.js",
    "test:knowledge": "node --test tests/categoryKnowledge.test.js",
    "test:errors": "node --test tests/errorRecovery.test.js",
    "lint": "eslint src/**/*.js server.js --fix"
  },
  "keywords": ["magicpin", "vera", "ai", "merchant", "whatsapp"],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "uuid": "^11.0.3",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "eslint": "^9.8.0",
    "nodemon": "^3.1.4"
  }
}
