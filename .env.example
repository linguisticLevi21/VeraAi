NODE_ENV=development
PORT=3000

# Bot Identity (returned by GET /v1/metadata)
TEAM_NAME=Team Vera
TEAM_MEMBERS=Your Name
BOT_MODEL=vera-deterministic-engine-v1
BOT_APPROACH=Deterministic 8-step reasoning pipeline: SignalExtractor -> InferenceEngine -> ReplayGuard -> StrategySelector -> ActionRanker -> strategy.compose() -> SuppressionEngine -> MessageComposer. No LLM. Same input always produces same output.
BOT_VERSION=1.0.0
BOT_SUBMITTED_AT=2026-07-08T00:00:00Z
CONTACT_EMAIL=your@email.com

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300

# Context
MAX_CONTEXT_SIZE_BYTES=512000
