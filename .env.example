NODE_ENV=development
PORT=3000

# Bot Identity (populated for /v1/metadata)
TEAM_NAME=Team Vera
TEAM_MEMBERS=Alice,Bob
BOT_MODEL=claude-opus-4-7
BOT_APPROACH=single-prompt composer with retrieval over digest items
CONTACT_EMAIL=team@example.com
BOT_VERSION=1.0.0

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# Security
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

# Context store
MAX_CONTEXT_SIZE_BYTES=512000
